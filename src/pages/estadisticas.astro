---
import Layout from "@/layouts/Layout.astro";
import { MainbarWrapper } from "@/components/MainbarWrapper";
import { ExportButton } from "@/components/ExportButton";
import lastUpdateData from "@/data/lastUpdate.json";
import ageData from "@/data/age.json";
import gobiernoData from "@/data/gobierno.json";
import congresoData from "@/data/congreso.json";
import senadoData from "@/data/senado.json";
import partidosData from "@/data/partidos.json";
import autonomiasData from "@/data/autonomias.json";
import universidadesData from "@/data/universidades.json";

const THIRTY_DAYS_MS = 30 * 24 * 60 * 60 * 1000;
const lu = lastUpdateData as any;

function platformRef(d: string | undefined) {
  return d ? new Date(d + "T00:00:00Z").getTime() : Date.now();
}

const TWITTER_REF  = platformRef(lu.twitter);
const BLUESKY_REF  = platformRef(lu.bluesky);
const MASTODON_REF = platformRef(lu.mastodon);

function isActiveDate(val: unknown, ref: number): boolean {
  if (!val || typeof val !== "string") return false;
  if (!/^\d{4}-\d{2}-\d{2}/.test(val)) return false;
  return ref - new Date(val).getTime() <= THIRTY_DAYS_MS;
}

function twitterOnX(handle: unknown, activo: unknown): boolean {
  if (!handle) return false;
  if (activo == null) return true;
  return isActiveDate(activo, TWITTER_REF);
}

function normalizeItem(item: any) {
  return {
    twitter:         item.twitter  || null,
    twitter_activo:  twitterOnX(item.twitter, item.twitter_activo),
    bluesky:         item.bluesky  || null,
    bluesky_activo:  isActiveDate(item.bluesky_activo, BLUESKY_REF),
    mastodon:        item.mastodon || null,
    mastodon_activo: isActiveDate(item.mastodon_activo, MASTODON_REF),
  };
}

const CATEGORIES = [
  { key: "age",           label: "Administración",  data: ageData           },
  { key: "gobierno",      label: "Gobierno",         data: gobiernoData      },
  { key: "congreso",      label: "Congreso",         data: congresoData      },
  { key: "senado",        label: "Senado",           data: senadoData        },
  { key: "partidos",      label: "Partidos",         data: partidosData      },
  { key: "autonomias",    label: "Autonomías",       data: autonomiasData    },
  { key: "universidades", label: "Universidades",    data: universidadesData },
];

const catStats = CATEGORIES.map(({ key, label, data }) => {
  const items = (data as any[]).map(normalizeItem);
  const total = items.length;
  const enX   = items.filter(x => x.twitter_activo).length;
  const conTwitter = items.filter(x => x.twitter).length;
  const conBluesky = items.filter(x => x.bluesky).length;
  const conMastodon = items.filter(x => x.mastodon).length;
  const bsActivo = items.filter(x => x.bluesky_activo).length;
  const mdActivo = items.filter(x => x.mastodon_activo).length;
  const fueraDeX = total - enX;
  const sinAlternativa = items.filter(x => !x.bluesky && !x.mastodon).length;
  return { key, label, total, enX, fueraDeX, conTwitter, conBluesky, conMastodon, bsActivo, mdActivo, sinAlternativa };
});

const totales = catStats.reduce(
  (acc, c) => ({
    total:         acc.total         + c.total,
    enX:           acc.enX           + c.enX,
    fueraDeX:      acc.fueraDeX      + c.fueraDeX,
    conTwitter:    acc.conTwitter    + c.conTwitter,
    conBluesky:    acc.conBluesky    + c.conBluesky,
    conMastodon:   acc.conMastodon   + c.conMastodon,
    bsActivo:      acc.bsActivo      + c.bsActivo,
    mdActivo:      acc.mdActivo      + c.mdActivo,
    sinAlternativa: acc.sinAlternativa + c.sinAlternativa,
  }),
  { total: 0, enX: 0, fueraDeX: 0, conTwitter: 0, conBluesky: 0, conMastodon: 0, bsActivo: 0, mdActivo: 0, sinAlternativa: 0 }
);

const conAlternativa = totales.total - totales.sinAlternativa;
const pctFueraDeX    = Math.round((totales.fueraDeX / totales.total) * 100);
const pctConAlt      = Math.round((conAlternativa    / totales.total) * 100);

function fmtDate(d: string | undefined) {
  if (!d) return "—";
  return new Date(d + "T00:00:00Z").toLocaleDateString("es-ES", {
    day: "numeric", month: "long", year: "numeric", timeZone: "UTC"
  });
}
---

<Layout
  title="Estadísticas · sal de ahí"
  description="Cifras sobre la presencia de instituciones públicas españolas en redes sociales."
>
  <h2
    slot="subtitle"
    class="mt-2 text-balance font-mono tracking-tight
           text-[11px] sm:text-xs md:text-sm max-w-xl mx-auto px-2 text-muted-foreground"
    transition:name="hero-subtitle"
  >
    Los gobiernos democráticos deberían habitar espacios democráticos.
    Exige a tus representantes que abandonen redes gobernadas por oligarcas.
  </h2>

  <div class="text-left px-4 sm:px-6 max-w-5xl mx-auto pb-16 mt-8">

    <div class="flex flex-wrap items-start justify-between gap-4 mb-8">
      <div>
        <h2 class="text-2xl font-semibold mb-1">Estadísticas</h2>
        <p class="text-sm text-muted-foreground">
          {totales.total} entidades públicas españolas. Última actualización:
          Twitter {fmtDate(lu.twitter)} · Bluesky/Mastodon {fmtDate(lu.bluesky)}.
        </p>
      </div>
      <ExportButton client:load />
    </div>

    <!-- KPIs principales -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      {[
        { label: "Entidades analizadas", value: totales.total,          sub: "instituciones" },
        { label: "Fuera de X",           value: totales.fueraDeX,       sub: `${pctFueraDeX}% del total` },
        { label: "Con alternativa federada", value: conAlternativa,     sub: `${pctConAlt}% del total` },
        { label: "Solo en X",            value: totales.sinAlternativa, sub: "sin red alternativa" },
      ].map(({ label, value, sub }) => (
        <div class="rounded-xl border bg-card text-card-foreground p-5 shadow-sm">
          <p class="text-3xl font-bold tabular-nums">{value}</p>
          <p class="text-sm font-medium mt-1">{label}</p>
          <p class="text-xs text-muted-foreground mt-0.5">{sub}</p>
        </div>
      ))}
    </div>

    <!-- Barras globales -->
    <div class="rounded-xl border bg-card text-card-foreground p-6 shadow-sm mb-6">
      <h3 class="text-base font-semibold mb-4">Estado global</h3>
      <MainbarWrapper
        client:load
        initialStats={{
          enX:            totales.enX,
          fueraDeX:       totales.fueraDeX,
          mastodon:       totales.conMastodon,
          bluesky:        totales.conBluesky - totales.conMastodon,
          sinAlternativa: totales.sinAlternativa,
        }}
      />
    </div>

    <!-- Tabla por categoría -->
    <div class="rounded-xl border bg-card text-card-foreground shadow-sm overflow-hidden mb-6">
      <div class="px-6 py-4 border-b">
        <h3 class="text-base font-semibold">Desglose por categoría</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b bg-muted/40 text-muted-foreground text-xs uppercase tracking-wide">
              <th class="px-4 py-3 text-left font-medium">Categoría</th>
              <th class="px-4 py-3 text-right font-medium">Total</th>
              <th class="px-4 py-3 text-right font-medium">Siguen en X</th>
              <th class="px-4 py-3 text-right font-medium">Fuera de X</th>
              <th class="px-4 py-3 text-right font-medium">Con Bluesky</th>
              <th class="px-4 py-3 text-right font-medium">Con Mastodon</th>
              <th class="px-4 py-3 text-right font-medium">Sin alternativa</th>
            </tr>
          </thead>
          <tbody>
            {catStats.map((c, i) => (
              <tr class={`border-b last:border-0 hover:bg-muted/30 transition-colors ${i % 2 === 0 ? '' : 'bg-muted/10'}`}>
                <td class="px-4 py-3 font-medium">{c.label}</td>
                <td class="px-4 py-3 text-right tabular-nums">{c.total}</td>
                <td class="px-4 py-3 text-right tabular-nums text-red-500">{c.enX}</td>
                <td class="px-4 py-3 text-right tabular-nums text-emerald-600">{c.fueraDeX}</td>
                <td class="px-4 py-3 text-right tabular-nums text-sky-500">{c.conBluesky}</td>
                <td class="px-4 py-3 text-right tabular-nums text-violet-500">{c.conMastodon}</td>
                <td class="px-4 py-3 text-right tabular-nums text-muted-foreground">{c.sinAlternativa}</td>
              </tr>
            ))}
            <!-- Fila totales -->
            <tr class="border-t-2 bg-muted/20 font-semibold">
              <td class="px-4 py-3">Total</td>
              <td class="px-4 py-3 text-right tabular-nums">{totales.total}</td>
              <td class="px-4 py-3 text-right tabular-nums text-red-500">{totales.enX}</td>
              <td class="px-4 py-3 text-right tabular-nums text-emerald-600">{totales.fueraDeX}</td>
              <td class="px-4 py-3 text-right tabular-nums text-sky-500">{totales.conBluesky}</td>
              <td class="px-4 py-3 text-right tabular-nums text-violet-500">{totales.conMastodon}</td>
              <td class="px-4 py-3 text-right tabular-nums text-muted-foreground">{totales.sinAlternativa}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Barras por categoría -->
    <div class="rounded-xl border bg-card text-card-foreground shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b">
        <h3 class="text-base font-semibold">Presencia en X por categoría</h3>
        <p class="text-xs text-muted-foreground mt-0.5">Porcentaje de entidades que siguen activas en X (rojo) vs fuera (verde)</p>
      </div>
      <div class="divide-y">
        {catStats.map(c => {
          const pctX = c.total > 0 ? Math.round((c.enX / c.total) * 100) : 0;
          return (
            <div class="px-6 py-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium">{c.label}</span>
                <span class="text-xs text-muted-foreground tabular-nums">{c.enX}/{c.total} en X</span>
              </div>
              <div class="flex h-2 w-full overflow-hidden rounded-full bg-muted">
                <div
                  class="h-full bg-emerald-500 rounded-l-full transition-[width]"
                  style={`width:${100 - pctX}%`}
                />
                <div
                  class="h-full bg-red-400 rounded-r-full transition-[width]"
                  style={`width:${pctX}%`}
                />
              </div>
              <div class="flex justify-between mt-1 text-xs text-muted-foreground">
                <span class="text-emerald-600">{c.fueraDeX} fuera ({100 - pctX}%)</span>
                <span class="text-red-500">{c.enX} en X ({pctX}%)</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>

  </div>
</Layout>
