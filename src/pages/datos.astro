---
import Layout from "@/layouts/Layout.astro";
import { ExportButton } from "@/components/ExportButton";
import lastUpdateData from "@/data/lastUpdate.json";
import ageData from "@/data/age.json";
import gobiernoData from "@/data/gobierno.json";
import congresoData from "@/data/congreso.json";
import senadoData from "@/data/senado.json";
import partidosData from "@/data/partidos.json";
import autonomiasData from "@/data/autonomias.json";
import universidadesData from "@/data/universidades.json";

const THIRTY_DAYS_MS = 30 * 24 * 60 * 60 * 1000;
const lu = lastUpdateData as any;

function platformRef(d: string | undefined) {
  return d ? new Date(d + "T00:00:00Z").getTime() : Date.now();
}
const TWITTER_REF  = platformRef(lu.twitter);
const BLUESKY_REF  = platformRef(lu.bluesky);
const MASTODON_REF = platformRef(lu.mastodon);

function isActiveDate(val: unknown, ref: number): boolean {
  if (!val || typeof val !== "string") return false;
  if (!/^\d{4}-\d{2}-\d{2}/.test(val)) return false;
  return ref - new Date(val).getTime() <= THIRTY_DAYS_MS;
}
function twitterOnX(handle: unknown, activo: unknown): boolean {
  if (!handle) return false;
  if (activo == null) return true;
  return isActiveDate(activo, TWITTER_REF);
}
function normalizeItem(item: any) {
  return {
    twitter:         item.twitter || null,
    twitter_activo:  twitterOnX(item.twitter, item.twitter_activo),
    bluesky:         item.bluesky  || null,
    bluesky_activo:  isActiveDate(item.bluesky_activo, BLUESKY_REF),
    mastodon:        item.mastodon || null,
    mastodon_activo: isActiveDate(item.mastodon_activo, MASTODON_REF),
    grupo:           item.grupo || null,
    tipo:            item.tipo || null,
  };
}

const CATEGORIES = [
  { key: "age",           label: "Administración",  data: ageData           },
  { key: "gobierno",      label: "Gobierno",         data: gobiernoData      },
  { key: "congreso",      label: "Congreso",         data: congresoData      },
  { key: "senado",        label: "Senado",           data: senadoData        },
  { key: "partidos",      label: "Partidos",         data: partidosData      },
  { key: "autonomias",    label: "Autonomías",       data: autonomiasData    },
  { key: "universidades", label: "Universidades",    data: universidadesData },
];

const catStats = CATEGORIES.map(({ key, label, data }) => {
  const items = (data as any[]).map(normalizeItem);
  const total          = items.length;
  const conTwitter     = items.filter(x => x.twitter).length;
  const enX            = items.filter(x => x.twitter_activo).length;
  const conBluesky     = items.filter(x => x.bluesky).length;
  const activoBsky     = items.filter(x => x.bluesky_activo).length;
  const conMastodon    = items.filter(x => x.mastodon).length;
  const activoMstdn    = items.filter(x => x.mastodon_activo).length;
  const sinAlternativa = items.filter(x => !x.bluesky && !x.mastodon).length;
  const sinNinguna     = items.filter(x => !x.twitter && !x.bluesky && !x.mastodon).length;
  const pctFuera       = total > 0 ? Math.round(((total - enX) / total) * 100) : 0;
  const pctBsky        = total > 0 ? Math.round((conBluesky / total) * 100) : 0;
  return { key, label, total, conTwitter, enX, conBluesky, activoBsky, conMastodon, activoMstdn, sinAlternativa, sinNinguna, pctFuera, pctBsky };
});

const totales = catStats.reduce(
  (acc, c) => ({
    total:          acc.total          + c.total,
    conTwitter:     acc.conTwitter     + c.conTwitter,
    enX:            acc.enX            + c.enX,
    conBluesky:     acc.conBluesky     + c.conBluesky,
    activoBsky:     acc.activoBsky     + c.activoBsky,
    conMastodon:    acc.conMastodon    + c.conMastodon,
    activoMstdn:    acc.activoMstdn    + c.activoMstdn,
    sinAlternativa: acc.sinAlternativa + c.sinAlternativa,
    sinNinguna:     acc.sinNinguna     + c.sinNinguna,
  }),
  { total: 0, conTwitter: 0, enX: 0, conBluesky: 0, activoBsky: 0, conMastodon: 0, activoMstdn: 0, sinAlternativa: 0, sinNinguna: 0 }
);

const conAlternativa = totales.total - totales.sinAlternativa;
const pctFueraDeX       = totales.total > 0 ? Math.round(((totales.total - totales.enX)  / totales.total) * 100) : 0;
const pctConAlt         = totales.total > 0 ? Math.round((conAlternativa                  / totales.total) * 100) : 0;
const pctEnX            = totales.total > 0 ? Math.round((totales.enX                     / totales.total) * 100) : 0;
const pctConTw          = totales.total > 0 ? Math.round((totales.conTwitter              / totales.total) * 100) : 0;
const pctBsky           = totales.total > 0 ? Math.round((totales.conBluesky             / totales.total) * 100) : 0;
const pctActivoBsky     = totales.conBluesky > 0 ? Math.round((totales.activoBsky        / totales.conBluesky) * 100) : 0;
const pctMstdn          = totales.total > 0 ? Math.round((totales.conMastodon            / totales.total) * 100) : 0;
const pctActivoMstdn    = totales.conMastodon > 0 ? Math.round((totales.activoMstdn      / totales.conMastodon) * 100) : 0;
const pctSinNinguna     = totales.total > 0 ? Math.round((totales.sinNinguna             / totales.total) * 100) : 0;
const pctNingW          = totales.total > 0 ? Math.round((totales.sinAlternativa         / totales.total) * 100) : 0;
const pctActBskyOfTotal = totales.total > 0 ? Math.round((totales.activoBsky             / totales.total) * 100) : 0;
const pctActMstdnOfTotal= totales.total > 0 ? Math.round((totales.activoMstdn            / totales.total) * 100) : 0;

// ── Congreso: por grupo parlamentario (solo diputados) ────────────────────────
const CONGRESO_GRUPO_LABELS: Record<string, string> = {
  "Grupo Parlamentario Popular en el Congreso":   "PP",
  "Grupo Parlamentario Socialista":               "PSOE",
  "Grupo Parlamentario VOX":                      "VOX",
  "Grupo Parlamentario Plurinacional SUMAR":      "SUMAR",
  "Grupo Parlamentario Mixto":                    "Mixto",
  "Grupo Parlamentario Junts per Catalunya":      "Junts",
  "Grupo Parlamentario Republicano":              "ERC",
  "Grupo Parlamentario Euskal Herria Bildu":      "EH Bildu",
  "Grupo Parlamentario Vasco (EAJ-PNV)":          "PNV",
};

type GrupoStat = { total: number; enX: number; fueraDeX: number; conBluesky: number; activoBsky: number; conMastodon: number };

const congresoGruposMap: Record<string, GrupoStat> = {};

for (const raw of congresoData as any[]) {
  if (raw.tipo !== "Diputado/a" || !raw.grupo) continue;
  const label = CONGRESO_GRUPO_LABELS[raw.grupo] ?? raw.grupo;
  if (!congresoGruposMap[label]) congresoGruposMap[label] = { total: 0, enX: 0, fueraDeX: 0, conBluesky: 0, activoBsky: 0, conMastodon: 0 };
  const g = congresoGruposMap[label];
  const item = normalizeItem(raw);
  g.total++;
  if (item.twitter_activo) g.enX++; else g.fueraDeX++;
  if (item.bluesky)        g.conBluesky++;
  if (item.bluesky_activo) g.activoBsky++;
  if (item.mastodon)       g.conMastodon++;
}

const CONGRESO_GRUPO_ORDER = ["PP", "PSOE", "VOX", "SUMAR", "ERC", "EH Bildu", "Junts", "PNV", "Mixto"];
const gruposStats = CONGRESO_GRUPO_ORDER
  .filter(k => congresoGruposMap[k])
  .map(k => ({
    label: k, ...congresoGruposMap[k],
    pctFuera: Math.round((congresoGruposMap[k].fueraDeX / congresoGruposMap[k].total) * 100),
    pctBsky:  Math.round((congresoGruposMap[k].conBluesky / congresoGruposMap[k].total) * 100),
  }));

// ── Senado: por grupo parlamentario ───────────────────────────────────────────
const SENADO_GRUPO_LABELS: Record<string, string> = {
  "GPP":      "PP",
  "GPS":      "PSOE",
  "GPERB":    "ERC / EH Bildu",
  "GPIC":     "IC",
  "GPPLU":    "Plurinacional",
  "GPV":      "PNV",
  "GPMX":     "Mixto",
  "GPEAJPNV": "PNV",
};

const senadoGruposMap: Record<string, GrupoStat> = {};

for (const raw of senadoData as any[]) {
  if (raw.tipo !== "Senador/a" || !raw.grupo) continue;
  const label = SENADO_GRUPO_LABELS[raw.grupo] ?? raw.grupo;
  if (!senadoGruposMap[label]) senadoGruposMap[label] = { total: 0, enX: 0, fueraDeX: 0, conBluesky: 0, activoBsky: 0, conMastodon: 0 };
  const g = senadoGruposMap[label];
  const item = normalizeItem(raw);
  g.total++;
  if (item.twitter_activo) g.enX++; else g.fueraDeX++;
  if (item.bluesky)        g.conBluesky++;
  if (item.bluesky_activo) g.activoBsky++;
  if (item.mastodon)       g.conMastodon++;
}

const SENADO_GRUPO_ORDER = ["PP", "PSOE", "ERC / EH Bildu", "IC", "Plurinacional", "PNV", "Mixto"];
const senadoGruposStats = SENADO_GRUPO_ORDER
  .filter(k => senadoGruposMap[k])
  .map(k => ({
    label: k, ...senadoGruposMap[k],
    pctFuera: Math.round((senadoGruposMap[k].fueraDeX / senadoGruposMap[k].total) * 100),
    pctBsky:  Math.round((senadoGruposMap[k].conBluesky / senadoGruposMap[k].total) * 100),
  }));

function fmtDate(d: string | undefined) {
  if (!d) return "—";
  return new Date(d + "T00:00:00Z").toLocaleDateString("es-ES", {
    day: "numeric", month: "long", year: "numeric", timeZone: "UTC",
  });
}
---

<Layout
  title="Datos · sal de ahí"
  description="Cifras y metodología sobre la presencia de instituciones públicas españolas en redes sociales."
>
  <h2
    slot="subtitle"
    class="mt-2 text-balance font-mono tracking-tight
           text-[11px] sm:text-xs md:text-sm max-w-xl mx-auto px-2 text-muted-foreground"
    transition:name="hero-subtitle"
  >
    Los gobiernos democráticos deberían habitar espacios democráticos.
    Exige a tus representantes que abandonen redes gobernadas por oligarcas.
  </h2>

  <div class="text-left px-4 sm:px-6 max-w-5xl mx-auto pb-16 mt-8 space-y-10">

    <!-- Cabecera -->
    <div class="flex items-center justify-between">
      <p class="text-xs text-muted-foreground">
        {totales.total} entidades · actualizado {fmtDate(lu.twitter)}
      </p>
      <ExportButton client:load />
    </div>

    <!-- Estadísticas clave -->
    <div class="border-y border-border/50 py-6 space-y-6">
      <div>
        <p class="text-[11px] font-medium text-muted-foreground mb-3 uppercase tracking-wide">Presencia registrada</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-x-8 gap-y-4">
          <div>
            <p class="text-xs text-muted-foreground mb-0.5">Entidades monitorizadas</p>
            <p class="text-2xl font-bold tabular-nums">{totales.total}</p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground mb-0.5">Con cuenta en X / Twitter</p>
            <p class="text-2xl font-bold tabular-nums">{pctConTw}%<span class="text-sm font-normal text-muted-foreground ml-1.5">({totales.conTwitter})</span></p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground mb-0.5">Con cuenta en Bluesky</p>
            <p class="text-2xl font-bold tabular-nums">{pctBsky}%<span class="text-sm font-normal text-muted-foreground ml-1.5">({totales.conBluesky})</span></p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground mb-0.5">Con cuenta en Mastodon</p>
            <p class="text-2xl font-bold tabular-nums">{pctMstdn}%<span class="text-sm font-normal text-muted-foreground ml-1.5">({totales.conMastodon})</span></p>
          </div>
        </div>
      </div>
      <div class="pt-6 border-t border-border/30">
        <p class="text-[11px] font-medium text-muted-foreground mb-3 uppercase tracking-wide">Actividad <span class="font-normal normal-case">(últimos 30 días desde la fecha de referencia)</span></p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-x-8 gap-y-4">
          <div>
            <p class="text-xs text-muted-foreground mb-0.5">Activas en X / Twitter</p>
            <p class="text-2xl font-bold tabular-nums">{pctEnX}%<span class="text-sm font-normal text-muted-foreground ml-1.5">({totales.enX})</span></p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground mb-0.5">Sin actividad en X</p>
            <p class="text-2xl font-bold tabular-nums">{pctFueraDeX}%<span class="text-sm font-normal text-muted-foreground ml-1.5">({totales.total - totales.enX})</span></p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground mb-0.5">Activas en Bluesky</p>
            <p class="text-2xl font-bold tabular-nums">{totales.activoBsky}<span class="text-sm font-normal text-muted-foreground ml-1.5">({pctActivoBsky}% de con BS)</span></p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground mb-0.5">Sin presencia en ninguna red</p>
            <p class="text-2xl font-bold tabular-nums">{totales.sinNinguna}<span class="text-sm font-normal text-muted-foreground ml-1.5">({pctSinNinguna}%)</span></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Distribución por plataforma -->
    <div>
      <h2 class="text-base font-semibold mb-1">Distribución por plataforma</h2>
      <p class="text-xs text-muted-foreground mb-5">Proporción de entidades con cuenta registrada (barra completa) y con actividad en los últimos 30 días (tramo oscuro) sobre el total de entidades monitorizadas.</p>
      <div class="space-y-5">
        <!-- X / Twitter -->
        <div>
          <div class="flex items-baseline justify-between mb-1.5 gap-4">
            <span class="text-sm font-medium">X / Twitter</span>
            <span class="text-xs tabular-nums text-muted-foreground shrink-0">{totales.conTwitter} con cuenta ({pctConTw}%) · {totales.enX} activas ({pctEnX}%)</span>
          </div>
          <div class="flex h-2 w-full overflow-hidden bg-border/30">
            <div class="h-full bg-foreground/75" style={`width:${pctEnX}%`} />
            <div class="h-full bg-foreground/20" style={`width:${pctConTw - pctEnX}%`} />
          </div>
        </div>
        <!-- Bluesky -->
        <div>
          <div class="flex items-baseline justify-between mb-1.5 gap-4">
            <span class="text-sm font-medium">Bluesky</span>
            <span class="text-xs tabular-nums text-muted-foreground shrink-0">{totales.conBluesky} con cuenta ({pctBsky}%) · {totales.activoBsky} activas ({pctActBskyOfTotal}% del total, {pctActivoBsky}% de con BS)</span>
          </div>
          <div class="flex h-2 w-full overflow-hidden bg-border/30">
            <div class="h-full bg-foreground/75" style={`width:${pctActBskyOfTotal}%`} />
            <div class="h-full bg-foreground/20" style={`width:${pctBsky - pctActBskyOfTotal}%`} />
          </div>
        </div>
        <!-- Mastodon -->
        <div>
          <div class="flex items-baseline justify-between mb-1.5 gap-4">
            <span class="text-sm font-medium">Mastodon</span>
            <span class="text-xs tabular-nums text-muted-foreground shrink-0">{totales.conMastodon} con cuenta ({pctMstdn}%) · {totales.activoMstdn} activas ({pctActMstdnOfTotal}% del total, {pctActivoMstdn}% de con MD)</span>
          </div>
          <div class="flex h-2 w-full overflow-hidden bg-border/30">
            <div class="h-full bg-foreground/75" style={`width:${pctActMstdnOfTotal}%`} />
            <div class="h-full bg-foreground/20" style={`width:${pctMstdn - pctActMstdnOfTotal}%`} />
          </div>
        </div>
        <!-- Sin alternativa -->
        <div>
          <div class="flex items-baseline justify-between mb-1.5 gap-4">
            <span class="text-sm font-medium">Sin alternativa a X <span class="font-normal text-muted-foreground">(sin Bluesky ni Mastodon)</span></span>
            <span class="text-xs tabular-nums text-muted-foreground shrink-0">{totales.sinAlternativa} ({pctNingW}%)</span>
          </div>
          <div class="flex h-2 w-full overflow-hidden bg-border/30">
            <div class="h-full bg-foreground/40" style={`width:${pctNingW}%`} />
          </div>
        </div>
      </div>
      <p class="text-[11px] text-muted-foreground/60 mt-3 flex gap-4">
        <span>▪ oscuro: activas en los últimos 30 días</span>
        <span>▪ claro: con cuenta, sin actividad reciente</span>
      </p>
    </div>

    <!-- Grupos parlamentarios -->
    <div>
      <h2 class="text-base font-semibold mb-1">Presencia por grupo parlamentario</h2>
      <p class="text-xs text-muted-foreground mb-5">XV Legislatura. Solo diputados/as y senadores/as con escaño actual; no incluye presidencia de cámara ni grupos como entidad. <em>Sin act. X</em>: sin publicación en X en los últimos 30 días. <em>BS activo</em>: con publicación en Bluesky en los últimos 30 días.</p>

      <!-- Congreso -->
      <p class="text-xs font-medium text-muted-foreground mb-2">Congreso de los Diputados</p>
      <div class="overflow-x-auto border border-border/50 mb-8">
        <table class="w-full table-fixed" data-sortable>
          <colgroup>
            <col />
            <col style="width:48px" />
            <col style="width:140px" />
            <col style="width:64px" />
            <col style="width:70px" />
            <col style="width:70px" />
            <col style="width:72px" />
          </colgroup>
          <thead>
            <tr class="border-b border-border/40 bg-muted/20">
              <th data-sort="grupo" class="sortable-th py-2 px-4 text-[11px] font-medium text-muted-foreground text-left">Grupo<span class="sort-ind"></span></th>
              <th data-sort="total" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">N<span class="sort-ind"></span></th>
              <th data-sort="pctFuera" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-left">Sin act. X<span class="sort-ind"></span></th>
              <th data-sort="enX" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">Act. X<span class="sort-ind"></span></th>
              <th data-sort="bsky" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">Bluesky<span class="sort-ind"></span></th>
              <th data-sort="bskyA" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">BS activo<span class="sort-ind"></span></th>
              <th data-sort="mstdn" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">Mastodon<span class="sort-ind"></span></th>
            </tr>
          </thead>
          <tbody>
            {gruposStats.map((g) => (
              <tr class="border-b border-border/30 hover:bg-muted/20 transition-colors">
                <td data-col="grupo" class="py-2 px-4 text-sm font-medium text-left truncate">{g.label}</td>
                <td data-col="total" data-val={g.total} class="py-2 px-3 text-sm tabular-nums text-right text-muted-foreground">{g.total}</td>
                <td data-col="pctFuera" data-val={g.pctFuera} class="py-2 px-3">
                  <div class="flex items-center gap-2">
                    <div class="flex h-1.5 w-14 overflow-hidden bg-border/30 shrink-0">
                      <div class="h-full bg-foreground/40" style={`width:${g.pctFuera}%`} />
                    </div>
                    <span class="text-xs tabular-nums text-muted-foreground shrink-0">{g.pctFuera}%</span>
                  </div>
                </td>
                <td data-col="enX" data-val={g.enX} class="py-2 px-3 text-sm tabular-nums text-right">{g.enX}</td>
                <td data-col="bsky" data-val={g.conBluesky} class="py-2 px-3 text-sm tabular-nums text-right">{g.conBluesky}</td>
                <td data-col="bskyA" data-val={g.activoBsky} class="py-2 px-3 text-sm tabular-nums text-right font-medium">{g.activoBsky}</td>
                <td data-col="mstdn" data-val={g.conMastodon} class="py-2 px-3 text-sm tabular-nums text-right">{g.conMastodon}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Senado -->
      <p class="text-xs font-medium text-muted-foreground mb-2">Senado de España</p>
      <div class="overflow-x-auto border border-border/50">
        <table class="w-full table-fixed" data-sortable>
          <colgroup>
            <col />
            <col style="width:48px" />
            <col style="width:140px" />
            <col style="width:64px" />
            <col style="width:70px" />
            <col style="width:70px" />
            <col style="width:72px" />
          </colgroup>
          <thead>
            <tr class="border-b border-border/40 bg-muted/20">
              <th data-sort="grupo" class="sortable-th py-2 px-4 text-[11px] font-medium text-muted-foreground text-left">Grupo<span class="sort-ind"></span></th>
              <th data-sort="total" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">N<span class="sort-ind"></span></th>
              <th data-sort="pctFuera" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-left">Sin act. X<span class="sort-ind"></span></th>
              <th data-sort="enX" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">Act. X<span class="sort-ind"></span></th>
              <th data-sort="bsky" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">Bluesky<span class="sort-ind"></span></th>
              <th data-sort="bskyA" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">BS activo<span class="sort-ind"></span></th>
              <th data-sort="mstdn" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">Mastodon<span class="sort-ind"></span></th>
            </tr>
          </thead>
          <tbody>
            {senadoGruposStats.map((g) => (
              <tr class="border-b border-border/30 hover:bg-muted/20 transition-colors">
                <td data-col="grupo" class="py-2 px-4 text-sm font-medium text-left truncate">{g.label}</td>
                <td data-col="total" data-val={g.total} class="py-2 px-3 text-sm tabular-nums text-right text-muted-foreground">{g.total}</td>
                <td data-col="pctFuera" data-val={g.pctFuera} class="py-2 px-3">
                  <div class="flex items-center gap-2">
                    <div class="flex h-1.5 w-14 overflow-hidden bg-border/30 shrink-0">
                      <div class="h-full bg-foreground/40" style={`width:${g.pctFuera}%`} />
                    </div>
                    <span class="text-xs tabular-nums text-muted-foreground shrink-0">{g.pctFuera}%</span>
                  </div>
                </td>
                <td data-col="enX" data-val={g.enX} class="py-2 px-3 text-sm tabular-nums text-right">{g.enX}</td>
                <td data-col="bsky" data-val={g.conBluesky} class="py-2 px-3 text-sm tabular-nums text-right">{g.conBluesky}</td>
                <td data-col="bskyA" data-val={g.activoBsky} class="py-2 px-3 text-sm tabular-nums text-right font-medium">{g.activoBsky}</td>
                <td data-col="mstdn" data-val={g.conMastodon} class="py-2 px-3 text-sm tabular-nums text-right">{g.conMastodon}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Desglose por categoría -->
    <div>
      <h2 class="text-base font-semibold mb-1">Desglose por categoría</h2>
      <p class="text-xs text-muted-foreground mb-4"><em>Act. X</em>: activos en X en los últimos 30 días. <em>↳ total</em>: total con cuenta en X (incluyendo inactivos). <em>BS activo</em>: activos en Bluesky en los últimos 30 días. <em>Sin red</em>: sin cuenta en ninguna de las tres plataformas.</p>
      <div class="overflow-x-auto border border-border/50">
        <table class="w-full table-fixed" data-sortable>
          <colgroup>
            <col />
            <col style="width:48px" />
            <col style="width:64px" />
            <col style="width:64px" />
            <col style="width:68px" />
            <col style="width:68px" />
            <col style="width:68px" />
            <col style="width:56px" />
          </colgroup>
          <thead>
            <tr class="border-b border-border/40 bg-muted/20">
              <th data-sort="cat" class="sortable-th py-2 px-4 text-[11px] font-medium text-muted-foreground text-left">Categoría<span class="sort-ind"></span></th>
              <th data-sort="total" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">N<span class="sort-ind"></span></th>
              <th data-sort="enX" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">Act. X<span class="sort-ind"></span></th>
              <th data-sort="conTw" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">↳ total<span class="sort-ind"></span></th>
              <th data-sort="bsky" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">Bluesky<span class="sort-ind"></span></th>
              <th data-sort="bskyA" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">BS activo<span class="sort-ind"></span></th>
              <th data-sort="mstdn" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">Mastodon<span class="sort-ind"></span></th>
              <th data-sort="sinNada" class="sortable-th py-2 px-3 text-[11px] font-medium text-muted-foreground text-right">Sin red<span class="sort-ind"></span></th>
            </tr>
          </thead>
          <tbody>
            {catStats.map((c) => (
              <tr class="border-b border-border/30 hover:bg-muted/20 transition-colors">
                <td data-col="cat" class="py-2 px-4 text-sm font-medium text-left truncate">{c.label}</td>
                <td data-col="total" data-val={c.total} class="py-2 px-3 text-sm tabular-nums text-right text-muted-foreground">{c.total}</td>
                <td data-col="enX" data-val={c.enX} class="py-2 px-3 text-sm tabular-nums text-right">{c.enX}</td>
                <td data-col="conTw" data-val={c.conTwitter} class="py-2 px-3 text-sm tabular-nums text-right text-muted-foreground">{c.conTwitter}</td>
                <td data-col="bsky" data-val={c.conBluesky} class="py-2 px-3 text-sm tabular-nums text-right">{c.conBluesky}</td>
                <td data-col="bskyA" data-val={c.activoBsky} class="py-2 px-3 text-sm tabular-nums text-right font-medium">{c.activoBsky}</td>
                <td data-col="mstdn" data-val={c.conMastodon} class="py-2 px-3 text-sm tabular-nums text-right">{c.conMastodon}</td>
                <td data-col="sinNada" data-val={c.sinNinguna} class="py-2 px-3 text-sm tabular-nums text-right text-muted-foreground">{c.sinNinguna}</td>
              </tr>
            ))}
            <tr data-footer class="border-t border-border bg-muted/20">
              <td class="py-2 px-4 text-sm font-semibold text-left">Total</td>
              <td class="py-2 px-3 text-sm tabular-nums font-semibold text-right text-muted-foreground">{totales.total}</td>
              <td class="py-2 px-3 text-sm tabular-nums font-semibold text-right">{totales.enX}</td>
              <td class="py-2 px-3 text-sm tabular-nums font-semibold text-right text-muted-foreground">{totales.conTwitter}</td>
              <td class="py-2 px-3 text-sm tabular-nums font-semibold text-right">{totales.conBluesky}</td>
              <td class="py-2 px-3 text-sm tabular-nums font-semibold text-right">{totales.activoBsky}</td>
              <td class="py-2 px-3 text-sm tabular-nums font-semibold text-right">{totales.conMastodon}</td>
              <td class="py-2 px-3 text-sm tabular-nums font-semibold text-right text-muted-foreground">{totales.sinNinguna}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Metodología -->
    <div class="pt-2 border-t border-border/40">
      <h2 class="text-base font-semibold mb-1">Metodología</h2>
      <p class="text-xs text-muted-foreground mb-8">Criterios de inclusión, proceso de obtención y verificación de los datos.</p>

      <div class="space-y-8 text-sm text-muted-foreground leading-relaxed max-w-3xl">

        <!-- 1. Alcance -->
        <div>
          <h3 class="text-sm font-semibold text-foreground mb-2">1. Alcance y unidad de análisis</h3>
          <p class="mb-3">
            El estudio cubre {totales.total} entidades distribuidas en siete categorías: Administración General del Estado (ministerios y organismos con rango de secretaría), Gobierno (presidente y ministros en activo), Congreso de los Diputados (institución, presidencia, grupos parlamentarios y diputados/as con escaño), Senado (ídem para senadores/as, incluyendo designados por comunidades autónomas), Partidos políticos (cuentas orgánicas de partidos con representación en el Congreso), Comunidades Autónomas (presidencias y asambleas autonómicas) y Universidades (centros reconocidos por el Ministerio de Universidades).
          </p>
          <p>
            Se excluyen organismos autónomos, agencias estatales, entidades locales y delegaciones territoriales. Los partidos de ámbito exclusivamente autonómico no tienen entrada propia en la categoría Partidos, aunque sus representantes sí figuran en Congreso y Senado.
          </p>
        </div>

        <!-- 2. Obtención de datos -->
        <div>
          <h3 class="text-sm font-semibold text-foreground mb-2">2. Obtención y verificación de handles</h3>
          <p class="mb-3">
            La identificación de cuentas sigue un proceso de dos fases. En la <strong class="text-foreground">fase automatizada</strong> se extraen las listas de «siguiendo» de perfiles institucionales semilla en X y Bluesky, y se aplica coincidencia aproximada (<em>fuzzy matching</em>) entre los nombres normalizados de cada entidad y el nombre de display de cada perfil candidato. Para Bluesky, la identidad se verifica mediante la API pública <code class="font-mono text-xs">public.api.bsky.app</code> (endpoint <code class="font-mono text-xs">app.bsky.actor.getProfile</code>), que devuelve el nombre real y la bio sin necesidad de autenticación. Para X, la verificación se realiza con GetXAPI.
          </p>
          <p class="mb-3">
            En la <strong class="text-foreground">fase de revisión manual</strong>, cada propuesta del sistema es aceptada, descartada o corregida individualmente. Se contrasta con webs oficiales, comunicados de prensa y referencias cruzadas entre plataformas. A cada asignación se le asigna un nivel de confianza:
          </p>
          <dl class="space-y-1.5 pl-4 border-l border-border/50 text-sm">
            <div class="flex gap-3"><dt class="font-medium text-foreground w-14 shrink-0">Alta</dt><dd>Nombre de display contiene todos los apellidos y el nombre, o el nombre institucional oficial completo.</dd></div>
            <div class="flex gap-3"><dt class="font-medium text-foreground w-14 shrink-0">Media</dt><dd>Nombre de display contiene dos apellidos o un apellido más nombre; contenido coherente con el cargo, validado manualmente.</dd></div>
            <div class="flex gap-3"><dt class="font-medium text-foreground w-14 shrink-0">Baja</dt><dd>Un único apellido sin otros indicadores — no se incluye en el dataset publicado.</dd></div>
          </dl>
        </div>

        <!-- 3. Verificación de actividad -->
        <div>
          <h3 class="text-sm font-semibold text-foreground mb-2">3. Verificación de actividad</h3>
          <p class="mb-2">
            La actividad en cada plataforma se comprueba periódicamente mediante consulta a APIs externas, almacenando la fecha de la última publicación detectada:
          </p>
          <ul class="space-y-2 pl-4 border-l border-border/50">
            <li><strong class="text-foreground">X / Twitter</strong> — endpoint <code class="font-mono text-xs">GET /twitter/user/tweets</code> (GetXAPI). Las cuentas con error <em>not found</em> o <em>suspended</em> se registran como <code class="font-mono text-xs">404</code>. Las cuentas con tweets protegidos pueden quedar registradas incorrectamente como inactivas.</li>
            <li><strong class="text-foreground">Bluesky</strong> — endpoint <code class="font-mono text-xs">app.bsky.feed.getAuthorFeed</code> (API pública, sin autenticación).</li>
            <li><strong class="text-foreground">Mastodon</strong> — endpoints <code class="font-mono text-xs">/api/v1/accounts/lookup</code> y <code class="font-mono text-xs">/api/v1/accounts/{"{id}"}/statuses</code> del servidor de cada perfil.</li>
          </ul>
          <p class="mt-3">
            Una cuenta se clasifica como <strong class="text-foreground">activa</strong> si su última publicación se produjo dentro de los 30 días anteriores a la fecha de referencia de cada plataforma (indicada más abajo). El umbral se aplica sobre esa fecha fija — no sobre la fecha de consulta — para que los resultados sean estables y reproducibles entre actualizaciones. Las cuentas existentes que no publicaron en ese período se clasifican como <strong class="text-foreground">inactivas</strong>.
          </p>
        </div>

        <!-- 4. Fechas de referencia -->
        <div>
          <h3 class="text-sm font-semibold text-foreground mb-2">4. Fechas de referencia</h3>
          <p class="mb-3">Última ejecución completa de los scripts de verificación de actividad. La actividad se mide contra estas fechas, no contra la fecha de consulta.</p>
          <table class="text-sm border-collapse">
            <thead>
              <tr class="border-b border-border/40">
                <th class="text-left font-medium text-foreground pr-8 pb-1.5">Plataforma</th>
                <th class="text-left font-medium text-foreground pb-1.5">Fecha de referencia</th>
              </tr>
            </thead>
            <tbody>
              {[
                { plat: "X / Twitter", fecha: fmtDate(lu.twitter)  },
                { plat: "Bluesky",     fecha: fmtDate(lu.bluesky)  },
                { plat: "Mastodon",    fecha: fmtDate(lu.mastodon) },
              ].map(({ plat, fecha }) => (
                <tr class="border-b border-border/20">
                  <td class="pr-8 py-1.5 text-muted-foreground">{plat}</td>
                  <td class="py-1.5">{fecha}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- 5. Limitaciones -->
        <div>
          <h3 class="text-sm font-semibold text-foreground mb-2">5. Limitaciones</h3>
          <ul class="space-y-2 pl-4 border-l border-border/50">
            {[
              ["Cobertura de parlamentarios", "La identificación de cuentas personales depende de su aparición en las listas de «siguiendo» de cuentas institucionales o de su localización por nombre. Pueden existir cuentas no registradas."],
              ["Tweets protegidos", "GetXAPI accede únicamente a publicaciones públicas; las cuentas con privacidad restringida pueden quedar registradas como inactivas."],
              ["Dependencia de GetXAPI", "La verificación en X utiliza un servicio de terceros; la API oficial de X no es accesible sin suscripción de pago."],
              ["Plataformas no cubiertas", "No se recogen cuentas de Instagram, Facebook, TikTok, LinkedIn ni YouTube. El estudio se limita a plataformas de comunicación pública institucional basadas en texto."],
              ["Cobertura territorial", "Se excluyen ayuntamientos, diputaciones, delegaciones territoriales y organismos sub-nacionales."],
              ["Desfase electoral", "Los datos de Congreso y Senado reflejan la composición en el momento de la última actualización; pueden existir desfases tras cambios en la composición de las cámaras."],
              ["Verificación de titularidad", "La asignación se basa en coincidencia de nombre y coherencia de contenido. En casos ambiguos la entrada se descarta; no se han obtenido confirmaciones formales de todos los titulares."],
            ].map(([title, desc]) => (
              <li><strong class="text-foreground">{title}.</strong> {desc}</li>
            ))}
          </ul>
        </div>

      </div>
    </div>

  </div>
</Layout>

<style>
  .sortable-th {
    cursor: pointer;
    user-select: none;
  }
  .sortable-th:hover {
    color: hsl(var(--foreground));
  }
  .sort-ind {
    font-size: 10px;
    margin-left: 2px;
    opacity: 0.5;
  }
</style>

<script>
  function initSortableTables() {
    document.querySelectorAll<HTMLTableElement>('table[data-sortable]').forEach(table => {
      const thead = table.querySelector('thead');
      const tbody = table.querySelector('tbody');
      if (!tbody) return;

      const allThs = thead?.querySelectorAll<HTMLElement>('th[data-sort]') ?? [];

      allThs.forEach(th => {
        th.addEventListener('click', () => {
          const col = th.dataset.sort!;
          const current = th.dataset.dir || '';
          const dir = current === 'asc' ? 'desc' : 'asc';

          allThs.forEach(h => {
            h.dataset.dir = '';
            const ind = h.querySelector('.sort-ind');
            if (ind) ind.textContent = '';
          });
          th.dataset.dir = dir;
          const ind = th.querySelector('.sort-ind');
          if (ind) ind.textContent = dir === 'asc' ? ' ↑' : ' ↓';

          const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr:not([data-footer])'));
          const footer = tbody.querySelector<HTMLTableRowElement>('tr[data-footer]');

          rows.sort((a, b) => {
            const aCell = a.querySelector<HTMLElement>(`td[data-col="${col}"]`);
            const bCell = b.querySelector<HTMLElement>(`td[data-col="${col}"]`);
            const aHasVal = aCell?.hasAttribute('data-val') ?? false;
            const bHasVal = bCell?.hasAttribute('data-val') ?? false;
            const av = aHasVal ? Number(aCell!.dataset.val) : (aCell?.textContent?.trim() ?? '');
            const bv = bHasVal ? Number(bCell!.dataset.val) : (bCell?.textContent?.trim() ?? '');
            if (av < bv) return dir === 'asc' ? -1 : 1;
            if (av > bv) return dir === 'asc' ? 1 : -1;
            return 0;
          });

          rows.forEach(r => tbody.appendChild(r));
          if (footer) tbody.appendChild(footer);
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initSortableTables);
</script>
