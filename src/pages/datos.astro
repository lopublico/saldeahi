---
import Layout from "@/layouts/Layout.astro";
import { ExportButton } from "@/components/ExportButton";
import lastUpdateData from "@/data/lastUpdate.json";
import ageData from "@/data/age.json";
import gobiernoData from "@/data/gobierno.json";
import congresoData from "@/data/congreso.json";
import senadoData from "@/data/senado.json";
import partidosData from "@/data/partidos.json";
import autonomiasData from "@/data/autonomias.json";
import universidadesData from "@/data/universidades.json";

const THIRTY_DAYS_MS = 30 * 24 * 60 * 60 * 1000;
const lu = lastUpdateData as any;

function platformRef(d: string | undefined) {
  return d ? new Date(d + "T00:00:00Z").getTime() : Date.now();
}
const TWITTER_REF  = platformRef(lu.twitter);
const BLUESKY_REF  = platformRef(lu.bluesky);
const MASTODON_REF = platformRef(lu.mastodon);

function isActiveDate(val: unknown, ref: number): boolean {
  if (!val || typeof val !== "string") return false;
  if (!/^\d{4}-\d{2}-\d{2}/.test(val)) return false;
  return ref - new Date(val).getTime() <= THIRTY_DAYS_MS;
}
function twitterOnX(handle: unknown, activo: unknown): boolean {
  if (!handle) return false;
  if (activo == null) return true;
  return isActiveDate(activo, TWITTER_REF);
}
function normalizeItem(item: any) {
  return {
    twitter:         item.twitter || null,
    twitter_activo:  twitterOnX(item.twitter, item.twitter_activo),
    bluesky:         item.bluesky  || null,
    bluesky_activo:  isActiveDate(item.bluesky_activo, BLUESKY_REF),
    mastodon:        item.mastodon || null,
    mastodon_activo: isActiveDate(item.mastodon_activo, MASTODON_REF),
    grupo:           item.grupo || null,
    tipo:            item.tipo || null,
  };
}

const CATEGORIES = [
  { key: "age",           label: "Administración",  data: ageData           },
  { key: "gobierno",      label: "Gobierno",         data: gobiernoData      },
  { key: "congreso",      label: "Congreso",         data: congresoData      },
  { key: "senado",        label: "Senado",           data: senadoData        },
  { key: "partidos",      label: "Partidos",         data: partidosData      },
  { key: "autonomias",    label: "Autonomías",       data: autonomiasData    },
  { key: "universidades", label: "Universidades",    data: universidadesData },
];

const catStats = CATEGORIES.map(({ key, label, data }) => {
  const items = (data as any[]).map(normalizeItem);
  const total          = items.length;
  const conTwitter     = items.filter(x => x.twitter).length;
  const enX            = items.filter(x => x.twitter_activo).length;
  const sinActX        = conTwitter - enX;
  const conBluesky     = items.filter(x => x.bluesky).length;
  const activoBsky     = items.filter(x => x.bluesky_activo).length;
  const conMastodon    = items.filter(x => x.mastodon).length;
  const activoMstdn    = items.filter(x => x.mastodon_activo).length;
  const sinAlternativa = items.filter(x => !x.bluesky && !x.mastodon).length;
  const sinNinguna     = items.filter(x => !x.twitter && !x.bluesky && !x.mastodon).length;
  const pctFuera       = total > 0 ? Math.round(((total - enX) / total) * 100) : 0;
  const pctBsky        = total > 0 ? Math.round((conBluesky / total) * 100) : 0;
  return { key, label, total, conTwitter, enX, sinActX, conBluesky, activoBsky, conMastodon, activoMstdn, sinAlternativa, sinNinguna, pctFuera, pctBsky };
});

const totales = catStats.reduce(
  (acc, c) => ({
    total:          acc.total          + c.total,
    conTwitter:     acc.conTwitter     + c.conTwitter,
    enX:            acc.enX            + c.enX,
    sinActX:        acc.sinActX        + c.sinActX,
    conBluesky:     acc.conBluesky     + c.conBluesky,
    activoBsky:     acc.activoBsky     + c.activoBsky,
    conMastodon:    acc.conMastodon    + c.conMastodon,
    activoMstdn:    acc.activoMstdn    + c.activoMstdn,
    sinAlternativa: acc.sinAlternativa + c.sinAlternativa,
    sinNinguna:     acc.sinNinguna     + c.sinNinguna,
  }),
  { total: 0, conTwitter: 0, enX: 0, sinActX: 0, conBluesky: 0, activoBsky: 0, conMastodon: 0, activoMstdn: 0, sinAlternativa: 0, sinNinguna: 0 }
);

const conAlternativa    = totales.total - totales.sinAlternativa;
const pctFueraDeX       = totales.total > 0 ? Math.round(((totales.total - totales.enX)  / totales.total) * 100) : 0;
const pctEnX            = totales.total > 0 ? Math.round((totales.enX                     / totales.total) * 100) : 0;
const pctConTw          = totales.total > 0 ? Math.round((totales.conTwitter              / totales.total) * 100) : 0;
const pctBsky           = totales.total > 0 ? Math.round((totales.conBluesky             / totales.total) * 100) : 0;
const pctActivoBsky     = totales.conBluesky > 0 ? Math.round((totales.activoBsky        / totales.conBluesky) * 100) : 0;
const pctMstdn          = totales.total > 0 ? Math.round((totales.conMastodon            / totales.total) * 100) : 0;
const pctActivoMstdn    = totales.conMastodon > 0 ? Math.round((totales.activoMstdn      / totales.conMastodon) * 100) : 0;
const pctSinNinguna     = totales.total > 0 ? Math.round((totales.sinNinguna             / totales.total) * 100) : 0;
const pctNingW          = totales.total > 0 ? Math.round((totales.sinAlternativa         / totales.total) * 100) : 0;
const pctActBskyOfTotal = totales.total > 0 ? Math.round((totales.activoBsky             / totales.total) * 100) : 0;
const pctActMstdnOfTotal= totales.total > 0 ? Math.round((totales.activoMstdn            / totales.total) * 100) : 0;

// ── Congreso: por grupo parlamentario (solo diputados) ────────────────────────
const CONGRESO_GRUPO_LABELS: Record<string, string> = {
  "Grupo Parlamentario Popular en el Congreso":   "PP",
  "Grupo Parlamentario Socialista":               "PSOE",
  "Grupo Parlamentario VOX":                      "VOX",
  "Grupo Parlamentario Plurinacional SUMAR":      "SUMAR",
  "Grupo Parlamentario Mixto":                    "Mixto",
  "Grupo Parlamentario Junts per Catalunya":      "Junts",
  "Grupo Parlamentario Republicano":              "ERC",
  "Grupo Parlamentario Euskal Herria Bildu":      "EH Bildu",
  "Grupo Parlamentario Vasco (EAJ-PNV)":          "PNV",
};

type GrupoStat = { total: number; enX: number; fueraDeX: number; conBluesky: number; activoBsky: number; conMastodon: number };

const congresoGruposMap: Record<string, GrupoStat> = {};

for (const raw of congresoData as any[]) {
  if (raw.tipo !== "Diputado/a" || !raw.grupo) continue;
  const label = CONGRESO_GRUPO_LABELS[raw.grupo] ?? raw.grupo;
  if (!congresoGruposMap[label]) congresoGruposMap[label] = { total: 0, enX: 0, fueraDeX: 0, conBluesky: 0, activoBsky: 0, conMastodon: 0 };
  const g = congresoGruposMap[label];
  const item = normalizeItem(raw);
  g.total++;
  if (item.twitter_activo) g.enX++; else g.fueraDeX++;
  if (item.bluesky)        g.conBluesky++;
  if (item.bluesky_activo) g.activoBsky++;
  if (item.mastodon)       g.conMastodon++;
}

const CONGRESO_GRUPO_ORDER = ["PP", "PSOE", "VOX", "SUMAR", "ERC", "EH Bildu", "Junts", "PNV", "Mixto"];
const gruposStats = CONGRESO_GRUPO_ORDER
  .filter(k => congresoGruposMap[k])
  .map(k => ({
    label: k, ...congresoGruposMap[k],
    pctFuera: Math.round((congresoGruposMap[k].fueraDeX / congresoGruposMap[k].total) * 100),
    pctBsky:  Math.round((congresoGruposMap[k].conBluesky / congresoGruposMap[k].total) * 100),
  }));

const congresoTotales = gruposStats.reduce(
  (acc, g) => ({ total: acc.total + g.total, enX: acc.enX + g.enX, fueraDeX: acc.fueraDeX + g.fueraDeX, conBluesky: acc.conBluesky + g.conBluesky, activoBsky: acc.activoBsky + g.activoBsky, conMastodon: acc.conMastodon + g.conMastodon }),
  { total: 0, enX: 0, fueraDeX: 0, conBluesky: 0, activoBsky: 0, conMastodon: 0 }
);

// ── Senado: por grupo parlamentario ───────────────────────────────────────────
const SENADO_GRUPO_LABELS: Record<string, string> = {
  "GPP":   "PP",
  "GPS":   "PSOE",
  "GPERB": "ERC / EH Bildu",
  "GPIC":  "Izq. Confederal",
  "GPPLU": "Plural",
  "GPV":   "PNV",
  "GPMX":  "Mixto",
};

const CONGRESO_GRUPO_FULLNAMES: Record<string, string> = {
  "PP":       "Partido Popular",
  "PSOE":     "Partido Socialista Obrero Español",
  "VOX":      "VOX",
  "SUMAR":    "Sumar",
  "ERC":      "Esquerra Republicana de Catalunya",
  "EH Bildu": "Euskal Herria Bildu",
  "Junts":    "Junts per Catalunya",
  "PNV":      "EAJ-PNV",
  "Mixto":    "Grupo Parlamentario Mixto",
};

const SENADO_GRUPO_FULLNAMES: Record<string, string> = {
  "PP":              "Partido Popular",
  "PSOE":            "Partido Socialista Obrero Español",
  "ERC / EH Bildu":  "Izquierdas por la Independencia (ERC + EH Bildu)",
  "Izq. Confederal": "Izquierda Confederal (Más Madrid, Compromís, ASG, Geroa Bai…)",
  "Plural":          "Grupo Plural (Junts, Coalición Canaria, BNG, AHI)",
  "PNV":             "Euzko Alderdi Jeltzalea – Partido Nacionalista Vasco",
  "Mixto":           "Grupo Parlamentario Mixto",
};

const senadoGruposMap: Record<string, GrupoStat> = {};

for (const raw of senadoData as any[]) {
  if (raw.tipo !== "Senador/a" || !raw.grupo) continue;
  const label = SENADO_GRUPO_LABELS[raw.grupo] ?? raw.grupo;
  if (!senadoGruposMap[label]) senadoGruposMap[label] = { total: 0, enX: 0, fueraDeX: 0, conBluesky: 0, activoBsky: 0, conMastodon: 0 };
  const g = senadoGruposMap[label];
  const item = normalizeItem(raw);
  g.total++;
  if (item.twitter_activo) g.enX++; else g.fueraDeX++;
  if (item.bluesky)        g.conBluesky++;
  if (item.bluesky_activo) g.activoBsky++;
  if (item.mastodon)       g.conMastodon++;
}

const SENADO_GRUPO_ORDER = ["PP", "PSOE", "ERC / EH Bildu", "Izq. Confederal", "Plural", "PNV", "Mixto"];
const senadoGruposStats = SENADO_GRUPO_ORDER
  .filter(k => senadoGruposMap[k])
  .map(k => ({
    label: k, ...senadoGruposMap[k],
    pctFuera: Math.round((senadoGruposMap[k].fueraDeX / senadoGruposMap[k].total) * 100),
    pctBsky:  Math.round((senadoGruposMap[k].conBluesky / senadoGruposMap[k].total) * 100),
  }));

const senadoTotales = senadoGruposStats.reduce(
  (acc, g) => ({ total: acc.total + g.total, enX: acc.enX + g.enX, fueraDeX: acc.fueraDeX + g.fueraDeX, conBluesky: acc.conBluesky + g.conBluesky, activoBsky: acc.activoBsky + g.activoBsky, conMastodon: acc.conMastodon + g.conMastodon }),
  { total: 0, enX: 0, fueraDeX: 0, conBluesky: 0, activoBsky: 0, conMastodon: 0 }
);

function fmtDate(d: string | undefined) {
  if (!d) return "—";
  return new Date(d + "T00:00:00Z").toLocaleDateString("es-ES", {
    day: "numeric", month: "long", year: "numeric", timeZone: "UTC",
  });
}

// ── Helpers para barras visuales ──────────────────────────────────────────────
function pct(num: number, den: number) {
  return den > 0 ? Math.round((num / den) * 100) : 0;
}
---

<Layout
  title="Datos · sal de ahí"
  description="Cifras y metodología sobre la presencia de instituciones públicas españolas en redes sociales."
>
  <h2
    slot="subtitle"
    class="mt-2 text-balance font-mono tracking-tight
           text-[11px] sm:text-xs md:text-sm max-w-xl mx-auto px-2 text-muted-foreground"
    transition:name="hero-subtitle"
  >
    Los gobiernos democráticos deberían habitar espacios democráticos.
    Exige a tus representantes que abandonen redes gobernadas por oligarcas.
  </h2>

  <!-- Aviso pantalla pequeña -->
  <div class="sm:hidden bg-foreground text-background text-xs px-4 py-3 text-center leading-snug">
    Esta página muestra tablas y gráficos que pueden no verse bien en pantallas pequeñas. Se recomienda acceder desde un ordenador.
  </div>

  <div class="text-left px-4 sm:px-6 max-w-screen-xl mx-auto pb-16 mt-8 space-y-12">

    <!-- Cabecera -->
    <div class="flex items-center justify-between">
      <p class="text-sm text-muted-foreground">
        {totales.total} entidades · actualizado {fmtDate(lu.twitter)}
      </p>
      <ExportButton client:load />
    </div>

    <!-- ── Estadísticas clave ──────────────────────────────────────────────── -->
    <div class="border-y border-border/50 py-8 space-y-8">
      <div>
        <p class="text-xs font-medium text-muted-foreground mb-5 uppercase tracking-widest">Presencia registrada</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-x-8 gap-y-6">
          <div>
            <p class="text-sm text-muted-foreground mb-1">Entidades monitorizadas</p>
            <p class="text-3xl font-bold tabular-nums">{totales.total}</p>
            <p class="text-sm text-muted-foreground mt-1">en 7 categorías</p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground mb-1">Con cuenta en X</p>
            <p class="text-3xl font-bold tabular-nums">{pctConTw}%</p>
            <p class="text-sm text-muted-foreground mt-1">{totales.conTwitter} entidades</p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground mb-1">Con cuenta en Bluesky</p>
            <p class="text-3xl font-bold tabular-nums">{pctBsky}%</p>
            <p class="text-sm text-muted-foreground mt-1">{totales.conBluesky} entidades</p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground mb-1">Con cuenta en Mastodon</p>
            <p class="text-3xl font-bold tabular-nums">{pctMstdn}%</p>
            <p class="text-sm text-muted-foreground mt-1">{totales.conMastodon} entidades</p>
          </div>
        </div>
      </div>
      <div class="pt-8 border-t border-border/30">
        <p class="text-xs font-medium text-muted-foreground mb-5 uppercase tracking-widest">Actividad <span class="font-normal normal-case">(últimos 30 días desde la fecha de referencia)</span></p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-x-8 gap-y-6">
          <div>
            <p class="text-sm text-muted-foreground mb-1">Activas en X</p>
            <p class="text-3xl font-bold tabular-nums">{pctEnX}%</p>
            <p class="text-sm text-muted-foreground mt-1">{totales.enX} entidades</p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground mb-1">Con cuenta en X, sin publicar</p>
            <p class="text-3xl font-bold tabular-nums">{totales.sinActX}</p>
            <p class="text-sm text-muted-foreground mt-1">{Math.round(totales.sinActX / totales.total * 100)}% del total</p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground mb-1">Activas en Bluesky</p>
            <p class="text-3xl font-bold tabular-nums">{totales.activoBsky}</p>
            <p class="text-sm text-muted-foreground mt-1">{pctActivoBsky}% de las que tienen cuenta</p>
          </div>
          <div>
            <p class="text-sm text-muted-foreground mb-1">Sin cuenta en ninguna red</p>
            <p class="text-3xl font-bold tabular-nums">{totales.sinNinguna}</p>
            <p class="text-sm text-muted-foreground mt-1">{pctSinNinguna}% del total</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Distribución por plataforma ────────────────────────────────────── -->
    <div>
      <h2 class="text-base font-semibold mb-1 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-muted-foreground shrink-0">
          <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/>
        </svg>
        Distribución por plataforma
      </h2>
      <p class="text-sm text-muted-foreground mb-6">Proporción del total de {totales.total} entidades con cuenta registrada (barra completa) y con actividad en los últimos 30 días (tramo oscuro).</p>
      <div class="space-y-5">
        <div>
          <div class="flex items-baseline justify-between mb-1.5 gap-4">
            <span class="text-sm font-medium">X / Twitter</span>
            <span class="text-xs tabular-nums text-muted-foreground shrink-0">{totales.conTwitter} con cuenta ({pctConTw}%) · {totales.enX} activas ({pctEnX}%) · {totales.sinActX} inactivas</span>
          </div>
          <div class="flex h-2.5 w-full overflow-hidden bg-border/30">
            <div class="h-full bg-foreground/75" style={`width:${pctEnX}%`} />
            <div class="h-full bg-foreground/20" style={`width:${pctConTw - pctEnX}%`} />
          </div>
        </div>
        <div>
          <div class="flex items-baseline justify-between mb-1.5 gap-4">
            <span class="text-sm font-medium">Bluesky</span>
            <span class="text-xs tabular-nums text-muted-foreground shrink-0">{totales.conBluesky} con cuenta ({pctBsky}%) · {totales.activoBsky} activas ({pctActBskyOfTotal}% del total)</span>
          </div>
          <div class="flex h-2.5 w-full overflow-hidden bg-border/30">
            <div class="h-full bg-sky-500/80" style={`width:${pctActBskyOfTotal}%`} />
            <div class="h-full bg-sky-500/25" style={`width:${pctBsky - pctActBskyOfTotal}%`} />
          </div>
        </div>
        <div>
          <div class="flex items-baseline justify-between mb-1.5 gap-4">
            <span class="text-sm font-medium">Mastodon</span>
            <span class="text-xs tabular-nums text-muted-foreground shrink-0">{totales.conMastodon} con cuenta ({pctMstdn}%) · {totales.activoMstdn} activas ({pctActMstdnOfTotal}% del total)</span>
          </div>
          <div class="flex h-2.5 w-full overflow-hidden bg-border/30">
            <div class="h-full bg-violet-500/80" style={`width:${pctActMstdnOfTotal}%`} />
            <div class="h-full bg-violet-500/25" style={`width:${pctMstdn - pctActMstdnOfTotal}%`} />
          </div>
        </div>
        <div>
          <div class="flex items-baseline justify-between mb-1.5 gap-4">
            <span class="text-sm font-medium">Sin alternativa a X <span class="font-normal text-muted-foreground">(sin Bluesky ni Mastodon)</span></span>
            <span class="text-xs tabular-nums text-muted-foreground shrink-0">{totales.sinAlternativa} ({pctNingW}%)</span>
          </div>
          <div class="flex h-2.5 w-full overflow-hidden bg-border/30">
            <div class="h-full bg-amber-500/60" style={`width:${pctNingW}%`} />
          </div>
        </div>
      </div>
      <div class="text-xs text-muted-foreground/60 mt-4 flex flex-wrap gap-x-5 gap-y-1.5">
        <span class="flex items-center gap-1.5">
          <span class="inline-flex gap-px shrink-0">
            <span class="inline-block w-2.5 h-2.5 bg-foreground/75 rounded-sm"></span>
            <span class="inline-block w-2.5 h-2.5 bg-sky-500/80 rounded-sm"></span>
            <span class="inline-block w-2.5 h-2.5 bg-violet-500/80 rounded-sm"></span>
          </span>
          Activas (últimos 30 días)
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-flex gap-px shrink-0">
            <span class="inline-block w-2.5 h-2.5 bg-foreground/20 rounded-sm"></span>
            <span class="inline-block w-2.5 h-2.5 bg-sky-500/25 rounded-sm"></span>
            <span class="inline-block w-2.5 h-2.5 bg-violet-500/25 rounded-sm"></span>
          </span>
          Con cuenta, sin actividad reciente
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-2.5 h-2.5 bg-amber-500/60 rounded-sm shrink-0"></span>
          Sin alternativa a X
        </span>
      </div>
    </div>

    <!-- ── Comparativa visual por categoría ───────────────────────────────── -->
    <div>
      <h2 class="text-base font-semibold mb-1 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-muted-foreground shrink-0">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
        </svg>
        Adopción por categoría
      </h2>
      <p class="text-sm text-muted-foreground mb-6">Presencia y actividad en cada plataforma como proporción del total de entidades de la categoría. Barras a escala 0–100 %.</p>

      <!-- Eje de referencia -->
      <div class="flex gap-0 mb-1 ml-[7rem] sm:ml-[9rem]">
        <div class="flex-1 flex justify-between pr-10 sm:pr-12">
          {[0,25,50,75,100].map(v => (
            <span class="text-xs text-muted-foreground/40 tabular-nums" style={v === 0 ? "" : "transform:translateX(50%)"}>{v}%</span>
          ))}
        </div>
      </div>
      <!-- Líneas guía -->
      <div class="relative space-y-4">
        <div class="absolute inset-y-0 ml-[7rem] sm:ml-[9rem] right-10 sm:right-12 pointer-events-none flex">
          {[25,50,75].map(v => (
            <div class="absolute top-0 bottom-0 border-l border-dashed border-border/25" style={`left:${v}%`} />
          ))}
        </div>

        {catStats.map(c => {
          const pXA  = pct(c.enX, c.total);
          const pXI  = pct(c.sinActX, c.total);
          const pBsA = pct(c.activoBsky, c.total);
          const pBsI = pct(c.conBluesky - c.activoBsky, c.total);
          const pMd  = pct(c.conMastodon, c.total);
          return (
            <div class="flex gap-2 sm:gap-3 items-start">
